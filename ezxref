#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import re
import zipfile
import tempfile
import sys

version = "1.2.5"
is_information = False

def convert_all_references_final(input_docx_path, output_docx_path=None):
    if output_docx_path is None:
        base_name = os.path.splitext(input_docx_path)[0]
        output_docx_path = f"{base_name}_xref.docx"

    with tempfile.TemporaryDirectory() as temp_dir:
        extract_dir = os.path.join(temp_dir, 'docx_content')
        with zipfile.ZipFile(input_docx_path, 'r') as zip_ref:
            zip_ref.extractall(extract_dir)
        
        document_xml_path = os.path.join(extract_dir, 'word', 'document.xml')
        with open(document_xml_path, 'r', encoding='utf-8') as f:
            content = f.read()
            
        # 1. XML 极致清理与合并 (解决 _GoBack 书签等导致的 [3] 被拆分问题)
        if is_information: print("执行 XML 极致清理与合并...")
        # 移除干扰匹配的所有书签标签 (通常在正文中不重要，除了我们要生成的)
        content = re.sub(r'<w:bookmarkStart[^>]*/>', '', content)
        content = re.sub(r'<w:bookmarkEnd[^>]*/>', '', content)
        content = re.sub(r'<w:proofErr[^>]*/>', '', content)
        
        # 合并相邻的文本运行 (更包容的正则)
        # 匹配格式：</w:t></w:r><w:r>(可能有 rPr)<w:t>
        # 这里的 .*? 是非贪婪匹配，确保只在两个相邻 run 之间合并
        content = re.sub(r'</w:t></w:r><w:r[^>]*>(?:<w:rPr>.*?</w:rPr>)?<w:t[^>]*>', '', content, flags=re.DOTALL)
        
        if is_information:
            print("XML 预处理完成：碎片化的 [3] 应已合拢")

        # 2. 深度识别：建立物理段落索引映射
        para_matches = list(re.finditer(r'<w:p[^>]*>.*?</w:p>', content, re.DOTALL))
        if not para_matches: return None

        class Paragraph:
            def __init__(self, match_obj):
                self.xml = match_obj.group(0)
                self.start = match_obj.start()
                self.end = match_obj.end()
                self.text = "".join(re.findall(r'<w:t[^>]*>(.*?)</w:t>', self.xml, re.DOTALL))
        
        paragraphs = [Paragraph(m) for m in para_matches]
        
        # 3. 统计和识别引用
        references_found = set(re.findall(r'\[(\d+)\]', content))
        
        # 检测需要转换的引用 (不在已有的交叉引用字段中)
        pure_text_refs = set()
        for p in paragraphs:
            # 简单策略：如果段落中包含 [n]，且该 [n] 不在 REF 字段内
            for r_num in re.findall(r'\[(\d+)\]', p.text):
                # 检查该 r_num 在 XML 中是否处于 fldChar 之后
                # 这里为了性能和简单性，直接查找段落 XML 中是否包含对应的 REF 字段
                if f"REF _Ref_Auto_{r_num}" not in p.xml:
                    pure_text_refs.add(r_num)

        if not pure_text_refs:
            if is_information: print("没有发现需要转换的新引用")
            return input_docx_path
            
        # 4. 定位参考文献部分
        ref_section_started = False
        ref_title_index = -1
        num_to_para_index = {}
        
        for i, p in enumerate(paragraphs):
            if not ref_section_started:
                if "参考文献" in p.text:
                    ref_section_started = True
                    ref_title_index = i
                continue
            
            # 书签定位策略：
            # 1. 优先在文本中找 [n]
            # 2. 如果没找到且属于该区域，可能由于自动编号未显示在 XML 中
            m = re.search(r'\[(\d+)\]', p.text)
            if m:
                num = m.group(1)
                if num in pure_text_refs and num not in num_to_para_index:
                    num_to_para_index[num] = i
        
        # 兜底：对于自动编号的文献，按顺序补齐
        # 如果有些 new_references 还没找到对应的段落，尝试按顺序分配给标题后的段落
        remaining_refs = sorted([r for r in pure_text_refs if r not in num_to_para_index], key=int)
        if remaining_refs:
            for i in range(ref_title_index + 1, len(paragraphs)):
                p = paragraphs[i]
                if not any(idx == i for idx in num_to_para_index.values()):
                    if remaining_refs:
                        ref_num = remaining_refs.pop(0)
                        num_to_para_index[ref_num] = i

        if ref_title_index == -1:
            print("错误: 未找到参考文献标题")
            return None

        # 5. 插入书签
        ref_bookmarks = {}
        bookmark_id = 20000
        
        for num, idx in num_to_para_index.items():
            p = paragraphs[idx]
            b_name = f"_Ref_Auto_{num}"
            ref_bookmarks[num] = b_name
            
            b_start = f'<w:bookmarkStart w:id="{bookmark_id}" w:name="{b_name}"/>'
            b_end = f'<w:bookmarkEnd w:id="{bookmark_id}"/>'
            
            if '<w:pPr>' in p.xml:
                new_xml = re.sub(r'(<w:pPr>.*?</w:pPr>)', rf'\1{b_start}', p.xml, flags=re.DOTALL)
            else:
                new_xml = p.xml.replace('<w:p', f'<w:p>{b_start}', 1)
            new_xml = new_xml.replace('</w:p>', f'{b_end}</w:p>')
            paragraphs[idx].xml = new_xml
            bookmark_id += 1
            if is_information: print(f"已为 [{num}] 创建书签")

        # 6. 转换正文引用
        total_conv = 0
        for num in sorted(pure_text_refs, key=int):
            if num not in ref_bookmarks: continue
            
            b_name = ref_bookmarks[num]
            target = f'[{num}]'
            replacement = (
                f'</w:t></w:r>'
                f'<w:r><w:fldChar w:fldCharType="begin"/></w:r>'
                f'<w:r><w:instrText xml:space="preserve"> REF {b_name} \\r \\h </w:instrText></w:r>'
                f'<w:r><w:fldChar w:fldCharType="separate"/></w:r>'
                f'<w:r><w:rPr><w:vertAlign w:val="superscript"/></w:rPr><w:t>[{num}]</w:t></w:r>'
                f'<w:r><w:fldChar w:fldCharType="end"/></w:r>'
                f'<w:r><w:t>'
            )
            
            for i in range(ref_title_index):
                if target in paragraphs[i].xml:
                    paragraphs[i].xml = paragraphs[i].xml.replace(target, replacement)
                    total_conv += 1

        # 7. 线性组装最终 XML
        new_content_parts = []
        last_pos = 0
        for i, p in enumerate(paragraphs):
            # 拼凑段落前的部分
            new_content_parts.append(content[last_pos:para_matches[i].start()])
            # 拼凑处理后的段落
            new_content_parts.append(p.xml)
            last_pos = para_matches[i].end()
        new_content_parts.append(content[last_pos:])
        
        final_xml = "".join(new_content_parts)
        
        with open(document_xml_path, 'w', encoding='utf-8') as f:
            f.write(final_xml)
        
        # 8. 打包
        with zipfile.ZipFile(output_docx_path, 'w', zipfile.ZIP_DEFLATED) as zipf:
            for root, dirs, files in os.walk(extract_dir):
                for file in files:
                    file_path = os.path.join(root, file)
                    arcname = os.path.relpath(file_path, extract_dir)
                    zipf.write(file_path, arcname)
                    
        if is_information: print(f"处理完成，总计转换 {total_conv} 处引用")
        return output_docx_path

def main():
    global is_information
    args = sys.argv[1:]
    if not args or '-h' in args:
        print("用法: ezxref <input.docx> [output.docx] [-i]")
        return
    if '-i' in args: is_information = True; args.remove('-i')
    input_file = args[0]
    output_file = args[1] if len(args) > 1 else None
    try:
        res = convert_all_references_final(input_file, output_file)
        if res: print(f"完成: {res}")
    except Exception as e:
        print(f"发生错误: {e}")

if __name__ == '__main__':
    main()
